<launch>
  <arg name="ns" default="traffic" />
  <arg name="use_sim_time" default="false" />

  <arg name="image_topic" default="/camera_3_undistorted/compressed" />
  <arg name="pub_detections" default="/traffic/detections" />
  <arg name="pub_image" default="/traffic/image_bbox/compressed" />

  <arg name="stage1_weights" default="0413_stage1.pt" />
  <arg name="car_state_weights" default="0415_stage2_car_yolo.pt" />
  <arg name="ped_state_weights" default="0415_stage2_ped_yolo.pt" />

  <arg name="det_conf" default="0.25" />
  <arg name="car_det_conf" default="0.5" />
  <arg name="ped_det_conf" default="0.3" />
  <arg name="iou" default="0.7" />
  <arg name="padding_ratio" default="0.1" />
  <arg name="imgsz" default="640" />
  <arg name="track_min_hits" default="3" />
  <arg name="track_max_missed" default="5" />
  <arg name="track_min_iou" default="0.01" />
  <arg name="device" default="auto" />
  <arg name="cls_device" default="auto" />

  <group ns="$(arg ns)">
    <param name="/use_sim_time" value="$(arg use_sim_time)" />

    <node
      pkg="traffic_pkg"
      type="inference_traffic.py"
      name="traffic_light_iou_inference_node"
      output="screen"
      respawn="true"
      respawn_delay="2">

      <param name="image_topic" value="$(arg image_topic)" />
      <param name="stage1_weights" value="$(arg stage1_weights)" />
      <param name="car_state_weights" value="$(arg car_state_weights)" />
      <param name="ped_state_weights" value="$(arg ped_state_weights)" />
      <param name="det_conf" value="$(arg det_conf)" />
      <param name="car_det_conf" value="$(arg car_det_conf)" />
      <param name="ped_det_conf" value="$(arg ped_det_conf)" />
      <param name="iou" value="$(arg iou)" />
      <param name="padding_ratio" value="$(arg padding_ratio)" />
      <param name="imgsz" value="$(arg imgsz)" />
      <param name="track_min_hits" value="$(arg track_min_hits)" />
      <param name="track_max_missed" value="$(arg track_max_missed)" />
      <param name="track_min_iou" value="$(arg track_min_iou)" />
      <param name="device" value="$(arg device)" />
      <param name="cls_device" value="$(arg cls_device)" />
      <param name="pub_detections_topic" value="$(arg pub_detections)" />
      <param name="pub_image_topic" value="$(arg pub_image)" />
    </node>
  </group>
</launch>
